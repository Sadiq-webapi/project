pipeline {
    agent any
    parameters {
        choice(name: 'terraformAction', choices: ['apply', 'destroy'], description: 'Action')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'prod'], description: 'Env')
    }
    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        AWS_DEFAULT_REGION    = 'ap-south-2'
    }
    stages {
        stage('Checkout') {
            steps {
                // Checkout into the root workspace
                git branch: 'terraform-projects', 
                    url: 'https://github.com/Sadiq-webapi/DevOps-Project-Series.git',
                    credentialsId: 'github-token'
            }
        }
      stage('Plan') {
            steps {
                // Ensure we use 'bat' and '&&' for Windows
                bat 'cd project-1 && terraform init'
                bat "cd project-1 && terraform plan -var=\"env=${params.ENVIRONMENT}\" -out tfplan"
                bat 'cd project-1 && terraform show -no-color tfplan > tfplan.txt'
            }
        }

        stage('Approval') {
            steps {
                script {
                    // Critical: Read the file from the project-1 subdirectory
                    def plan = readFile 'project-1/tfplan.txt'
                    input message: "Review the plan for ${params.ENVIRONMENT}?",
                          parameters: [text(name: 'Plan', defaultValue: plan, description: 'Terraform Plan Output')]
                }
            }
        }

        stage('Apply or Destroy') {
            when { expression { return params.terraformAction == 'apply' || params.terraformAction == 'destroy' } }
            steps {
                script {
                    if (params.terraformAction == 'apply') {
                        bat 'cd project-1 && terraform apply -input=false tfplan'
                    } else {
                        bat "cd project-1 && terraform destroy -var=\"env=${params.ENVIRONMENT}\" -auto-approve"
                    }
                }
            }
        }
